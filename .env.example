# Shared local development env (single place)
# Copy to .env and fill with real values.

# App / Server
PORT=5000
NODE_ENV=development
APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176
ALLOW_LOCAL_CORS=true
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Web (Vite)
# Keep empty to use same-origin /api (recommended with Vite proxy in dev).
VITE_API_URL=
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Telegram bot
BOT_TOKEN=123456:replace_with_real_token
BOT_INTERNAL_API_KEY=replace_with_long_random_secret_32_plus
BOT_WEB_APP_URL=http://localhost:5173
BACKEND_API_URL=http://localhost:5000
TELEGRAM_BOT_USERNAME=sypev_bot
BOT_REQUEST_TIMEOUT_MS=12000

# Optional bot branding
BOT_BRAND_ANIMATION_URL=http://localhost:5173/brand/sypev-logo-animated.gif
BOT_BRAND_ANIMATION_COOLDOWN_SEC=21600
