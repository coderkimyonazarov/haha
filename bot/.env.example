# Telegram bot token from BotFather
BOT_TOKEN=123456:replace_with_real_token

# Internal secret used by bot -> server internal API
BOT_INTERNAL_API_KEY=replace_with_long_random_secret_32_plus

# Your deployed backend URL (same domain as web app)
BACKEND_API_URL=https://www.sypev.com

# Public web app URL for deep links/buttons
BOT_WEB_APP_URL=https://www.sypev.com

# Optional: for prettier deep link copy
TELEGRAM_BOT_USERNAME=sypev_bot

NODE_ENV=development
BOT_REQUEST_TIMEOUT_MS=12000
