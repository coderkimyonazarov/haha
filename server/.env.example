PORT=5000
NODE_ENV=development
DB_PATH=./data/dev.sqlite
APP_URL=http://localhost:5173
APP_AUTH_JWT_SECRET=replace_with_long_random_secret_for_custom_jwt
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=your_admin_password_hash_here
ADMIN_PASSWORD=changeme_in_production
ADMIN_SECRET=your_admin_secret_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username_without_at
TELEGRAM_WIDGET_DOMAIN=localhost
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=app-password
# SMTP_FROM=Sypev <no-reply@sypev.com>

# Telefon orqali SMS jo'natish (Tez orada...)
SMS_PROVIDER=dev
# TWILIO_ACCOUNT_SID=ACxxx
# TWILIO_AUTH_TOKEN=xxx
# TWILIO_FROM_NUMBER=+1234567890
CORS_ORIGIN=http://localhost:5173
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=postgresql://postgres:password@host:6543/postgres?pgbouncer=true

# AI Providers (At least one is required for AI features)
# OpenRouter API Key (Recommended for multiple models)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq API Key (Fast & Free)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key (Optional)
OPENAI_API_KEY=your_openai_api_key_here
