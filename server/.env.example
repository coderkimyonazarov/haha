# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
DB_PATH=./data/dev.sqlite
APP_URL=http://localhost:5173

# Admin
ADMIN_USERNAME=admin
# Generate with: node -e "require('argon2').hash('your-password').then(h=>console.log(h))"
# ADMIN_PASSWORD_HASH=$argon2id$v=19$m=65536,t=3,p=4$...
ADMIN_PASSWORD=changeme_in_production
ADMIN_SECRET=sypev_admin_secret_change_in_production_at_least_32_chars

# Telegram Login Widget
# Get from @BotFather
# TELEGRAM_BOT_TOKEN=1234567890:ABC-DEF

# Google OAuth2
# From https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxx
# GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# SMTP (for email verification & password reset)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=app-password
# SMTP_FROM=Sypev <no-reply@sypev.com>

# SMS Provider (phone OTP)
SMS_PROVIDER=dev
# TWILIO_ACCOUNT_SID=ACxxx
# TWILIO_AUTH_TOKEN=xxx
# TWILIO_FROM_NUMBER=+1234567890

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:5173

# AI (existing)
# OPENAI_API_KEY=sk-xxx
