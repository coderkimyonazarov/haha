{
  "name": "sypev",
  "private": true,
  "workspaces": [
    "bot",
    "server",
    "web",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\" \"npm:dev:bot\"",
    "dev:server": "npm --workspace server run dev",
    "dev:web": "NODE_ENV=development npm --workspace web run dev",
    "dev:bot": "NODE_ENV=development node scripts/has-bot-env.cjs && NODE_ENV=development npm --workspace bot run dev || echo \"[dev:bot] skipped: set BOT_TOKEN and BOT_INTERNAL_API_KEY in server/.env, .env, or bot/.env\"",
    "build": "npm --workspace server run build && npm --workspace web run build && npm --workspace bot run build",
    "start": "concurrently -k \"npm:start:server\" \"npm:start:bot\"",
    "start:server": "npm --workspace server run start",
    "start:bot": "npm --workspace bot run start",
    "test": "npm --workspace server run test"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.3",
    "postgres": "^3.4.8",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.31.9"
  }
}
